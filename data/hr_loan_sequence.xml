<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_hr_loan" model="ir.sequence">
            <field name="name">Employee Loan</field>
            <field name="code">hr.loan</field>
            <field name="prefix">LOAN/%(year)s/</field>
            <field name="padding">5</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_hr_loan_payment" model="ir.sequence">
            <field name="name">Loan Payment</field>
            <field name="code">hr.loan.payment</field>
            <field name="prefix">LPAY/%(year)s/</field>
            <field name="padding">5</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
