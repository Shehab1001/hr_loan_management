<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_loan_config_form" model="ir.ui.view">
        <field name="name">hr.loan.config.form</field>
        <field name="model">hr.loan.config</field>
        <field name="arch" type="xml">
            <form string="Loan Accounting Configuration">
                <sheet>
                    <div class="oe_title">
                        <h1>Loan Configuration — <field name="company_id" readonly="1"/></h1>
                    </div>
                    <group string="Accounting Setup">
                        <group>
                            <field name="loan_journal_id"/>
                            <field name="loan_account_id"/>
                        </group>
                        <group>
                            <field name="disbursal_account_id"/>
                            <field name="repayment_account_id"/>
                        </group>
                    </group>
                    <group string="Loan Limits">
                        <group>
                            <field name="max_loan_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="max_installments"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>How it works:</strong>
                        When a loan is <b>Disbursed</b>, the system debits the
                        <b>Loan Receivable Account</b> and credits the <b>Disbursal Account</b>.
                        When a repayment is posted, the system debits the <b>Repayment Account</b>
                        and credits the <b>Loan Receivable Account</b>.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_loan_config_tree" model="ir.ui.view">
        <field name="name">hr.loan.config.tree</field>
        <field name="model">hr.loan.config</field>
        <field name="arch" type="xml">
            <tree string="Loan Configurations">
                <field name="company_id"/>
                <field name="loan_journal_id"/>
                <field name="loan_account_id"/>
                <field name="max_loan_amount"/>
                <field name="max_installments"/>
            </tree>
        </field>
    </record>

    <record id="action_hr_loan_config" model="ir.actions.act_window">
        <field name="name">Loan Configuration</field>
        <field name="res_model">hr.loan.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
