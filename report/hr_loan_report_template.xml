<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_hr_loan_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="row mt-4 mb-4">
                            <div class="col-12 text-center">
                                <h2>
                                    <t t-if="doc.loan_type == 'loan'">Employee Loan Agreement</t>
                                    <t t-else="">Advance Salary Request</t>
                                </h2>
                                <h4 class="text-muted">
                                    <t t-esc="doc.name"/>
                                </h4>
                            </div>
                        </div>

                        <hr/>

                        <!-- Employee & Loan Details -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Employee:</strong></td>
                                        <td><t t-esc="doc.employee_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Department:</strong></td>
                                        <td><t t-esc="doc.department_id.name or '—'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Job Position:</strong></td>
                                        <td><t t-esc="doc.job_id.name or '—'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Company:</strong></td>
                                        <td><t t-esc="doc.company_id.name"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Reference:</strong></td>
                                        <td><t t-esc="doc.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Request Date:</strong></td>
                                        <td><t t-esc="doc.date_request"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Approval Date:</strong></td>
                                        <td><t t-esc="doc.date_approved or '—'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td>
                                            <span t-attf-class="badge #{doc.state == 'validate' and 'bg-success' or doc.state == 'refuse' and 'bg-danger' or 'bg-warning'}">
                                                <t t-esc="dict(doc._fields['state'].selection)[doc.state]"/>
                                            </span>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Financial Summary -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-1">Financial Summary</h5>
                                <table class="table table-sm table-bordered">
                                    <tr class="table-primary">
                                        <th>Loan Amount</th>
                                        <th>No. of Installments</th>
                                        <th>Monthly Installment</th>
                                        <th>Total Paid</th>
                                        <th>Remaining Balance</th>
                                    </tr>
                                    <tr>
                                        <td>
                                            <t t-esc="doc.currency_id.symbol"/>
                                            <t t-esc="'{:,.2f}'.format(doc.loan_amount)"/>
                                        </td>
                                        <td><t t-esc="doc.installment"/></td>
                                        <td>
                                            <t t-esc="doc.currency_id.symbol"/>
                                            <t t-esc="'{:,.2f}'.format(doc.installment_amount)"/>
                                        </td>
                                        <td>
                                            <t t-esc="doc.currency_id.symbol"/>
                                            <t t-esc="'{:,.2f}'.format(doc.total_paid)"/>
                                        </td>
                                        <td>
                                            <t t-esc="doc.currency_id.symbol"/>
                                            <t t-esc="'{:,.2f}'.format(doc.total_remaining)"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Repayment Schedule -->
                        <t t-if="doc.loan_lines">
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h5 class="border-bottom pb-1">Repayment Schedule</h5>
                                    <table class="table table-sm table-striped table-bordered">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>#</th>
                                                <th>Due Date</th>
                                                <th>Amount</th>
                                                <th>Paid On</th>
                                                <th>Via Payslip</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="doc.loan_lines" t-as="line">
                                                <tr t-attf-class="#{line.paid and 'table-success' or ''}">
                                                    <td><t t-esc="line_index + 1"/></td>
                                                    <td><t t-esc="line.date"/></td>
                                                    <td>
                                                        <t t-esc="doc.currency_id.symbol"/>
                                                        <t t-esc="'{:,.2f}'.format(line.amount)"/>
                                                    </td>
                                                    <td><t t-esc="line.paid_date or '—'"/></td>
                                                    <td><t t-esc="line.payslip_id.name or '—'"/></td>
                                                    <td>
                                                        <t t-if="line.paid">
                                                            <span class="badge bg-success">Paid</span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-warning">Pending</span>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </t>

                        <!-- Notes -->
                        <t t-if="doc.notes">
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h5 class="border-bottom pb-1">Notes</h5>
                                    <p><t t-esc="doc.notes"/></p>
                                </div>
                            </div>
                        </t>

                        <!-- Signature Block -->
                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <div class="border-top pt-2">Employee Signature</div>
                                <p class="text-muted small"><t t-esc="doc.employee_id.name"/></p>
                            </div>
                            <div class="col-4 text-center">
                                <div class="border-top pt-2">HR Manager</div>
                                <p class="text-muted small"><t t-esc="doc.approved_by.name or '—'"/></p>
                            </div>
                            <div class="col-4 text-center">
                                <div class="border-top pt-2">Finance / Director</div>
                                <p class="text-muted small">Authorized Signatory</p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
